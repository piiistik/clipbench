<?xml version="1.0" encoding="UTF-8"?>
<Parts>
    <Static>
        .\bin\djikstra.exe
    </Static>

    <Dynamic prefix="--vertices ">
        <Int min="100" max="5000" step="1"/>
    </Dynamic>

    <Dynamic prefix="--edges ">
        <Int min="500" max="50000" step="1"/>
    </Dynamic>

    <Dynamic prefix="--source ">
        <Int min="0" max="999" step="1"/>
    </Dynamic>

    <Dynamic prefix="--target ">
        <Int min="0" max="999" step="1"/>
    </Dynamic>

    <Dynamic prefix="--seed ">
        <Int min="1" max="1000000" step="1"/>
    </Dynamic>

    <Static>
        --delay 0.5
    </Static>
</Parts>
