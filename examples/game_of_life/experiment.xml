<?xml version="1.0" encoding="UTF-8"?>
<Parts>
    <Static>
        .\bin\game_of_life.exe
    </Static>

    <Dynamic prefix="--width ">
        <Int min="64" max="512" step="1"/>
    </Dynamic>

    <Dynamic prefix="--height ">
        <Int min="64" max="512" step="1"/>
    </Dynamic>

    <Dynamic prefix="--generations ">
        <Int min="10" max="100" step="1"/>
    </Dynamic>

    <Dynamic prefix="--density ">
        <Int min="5" max="50" step="1"/>
    </Dynamic>

    <Dynamic prefix="--wraparound ">
        <Int min="0" max="1" step="1"/>
    </Dynamic>

    <Static>
        --delay 0
    </Static>
</Parts>
